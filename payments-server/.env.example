# Copy this file to .env and fill in your real values. Never commit .env.

# Get this from your Paystack dashboard → Settings → API Keys & Webhooks.
# Use a test key (sk_test_...) while developing, live key (sk_live_...) once ready.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The URL your app is hosted at (e.g. https://moriasi-manage.web.app).
# Restricts who can call this backend. Use * only while testing locally.
ALLOWED_ORIGIN=*

PORT=4000
